<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- 🦫 THÈME RONGEBOIS : Jaune et marron - Castor -->

    <!-- Couleurs de fond -->
    <Color x:Key="BackgroundDark">#1A1410</Color>
    <Color x:Key="BackgroundCard">#2A1F18</Color>
    <Color x:Key="BorderColor">#92400E</Color>

    <!-- Couleurs de texte -->
    <Color x:Key="TextPrimary">White</Color>
    <Color x:Key="TextSecondary">#D4D4D4</Color>

    <!-- Couleurs d'accent -->
    <Color x:Key="AccentGold">#FCD34D</Color>
    <Color x:Key="AccentOrange">#F59E0B</Color>
    <Color x:Key="AccentRed">#92400E</Color>
    <Color x:Key="AccentSecondary">#FDE68A</Color>

    <!-- Boutons et contrôles -->
    <Color x:Key="ButtonBackground">#92400E</Color>
    <Color x:Key="ButtonBackgroundHover">#A65020</Color>

</ResourceDictionary>
